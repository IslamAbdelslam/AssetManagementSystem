# ══════════════════════════════════════════════════════════════════════════════
# DarkAtlas Asset Management System — Environment Configuration
# Copy this file to .env and fill in ALL values before running.
# NEVER commit .env to git. This file (.env.example) is safe to commit.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development                # development | production
APP_DEBUG=false                    # Never true in production
DOCS_ENABLED=true                  # Set false in production (hides /docs)
SEED_ON_STARTUP=false              # true = load sample_dataset.json on first run

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://darkatlas:CHANGE_ME_32CHARS@localhost:5432/darkatlas_db
# For tenant isolation=database mode, also set:
META_DATABASE_URL=postgresql+asyncpg://darkatlas:CHANGE_ME_32CHARS@localhost:5432/darkatlas_meta

# ── Multi-Tenancy ──────────────────────────────────────────────────────────────
# row      = org_id FK column (default, simpler)
# database = separate PostgreSQL DB per org (requires PG superuser)
TENANT_ISOLATION=row

# ── Auth — JWT RS256 ──────────────────────────────────────────────────────────
# Generate with: openssl genrsa -out private.pem 2048 && cat private.pem | base64 -w 0
JWT_PRIVATE_KEY_B64=REPLACE_WITH_BASE64_ENCODED_RSA_PRIVATE_KEY_PEM
JWT_PUBLIC_KEY_B64=REPLACE_WITH_BASE64_ENCODED_RSA_PUBLIC_KEY_PEM
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Celery ─────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── AI — Google Gemini ────────────────────────────────────────────────────────
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-3.5-flash

# ── Lifecycle ──────────────────────────────────────────────────────────────────
STALE_THRESHOLD_DAYS=30            # Assets not seen in N days → stale

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_WRITE=60/minute         # Per JWT subject on write endpoints
RATE_LIMIT_BULK=5/minute           # Per org on bulk import
RATE_LIMIT_AI=20/minute            # Per org on AI endpoints

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
